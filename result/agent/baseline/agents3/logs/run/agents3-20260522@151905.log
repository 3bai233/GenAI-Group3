from openpyxl import load_workbook

# Load the workbook and active sheet
workbook_path = "Student_Grades_and_Remarks.xlsx"
wb = load_workbook(workbook_path)
sheet = wb.active

# Define the remark scale
scale = [
    (0, "Fail"),
    (30, "Pass"),
    (60, "Average"),
    (80, "Above average"),
    (90, "Excellent"),
    (100, "Exceptional")
]

# Function to return the remark based on marks
def get_remark(marks):
    for score, remark in reversed(scale):
        if marks >= score:
            return remark
    return "Unknown"

# Loop through student marks and assign remarks
for row in range(10, 24):  # Rows where student marks are located
    marks_cell = f"D{row}"
    message_cell = f"F{row}"
    marks = sheet[marks_cell].value
    if isinstance(marks, (int, float)):  # Ensure the marks are numeric
        sheet[message_cell] = get_remark(marks)

# Save the workbook with changes
wb.save(workbook_path)
```
</answer>
