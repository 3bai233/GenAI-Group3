from docx import Document
from docx.shared import Pt
import os

# Step 2: Create a Word document and add the text content
desktop_path = os.path.join(os.path.expanduser("~"), "Desktop")
doc_path = os.path.join(desktop_path, "concat.docx")

document = Document()
paragraph = document.add_paragraph(all_text_contents)

# Set the font size to 10
for run in paragraph.runs:
    run.font.size = Pt(10)

# Save the document
document.save(doc_path)
print(f"Document saved successfully at: {doc_path}")
```
</answer>
