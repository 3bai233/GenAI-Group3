from odf.opendocument import load
from odf.table import Table, TableCell, TableRow
from odf.text import P

# Load the .ods file
doc = load("Padding_Decimals_In_Formular.ods")
sheets = doc.spreadsheet.getElementsByType(Table)

# Access the first sheet
sheet = sheets[0]

# Update cell C2 (2nd row, 3rd column) with the desired formula
rows = sheet.getElementsByType(TableRow)
row = rows[1]
cell = row.getElementsByType(TableCell)[2]
cell.clearContent()  # Clear existing content
cell.setAttribute("formula", 'of:=TEXT([.$A$2], "0.00")')
cell.addElement(P(text=''))

# Save the modified file
doc.save("Padding_Decimals_In_Formular.ods")
```

