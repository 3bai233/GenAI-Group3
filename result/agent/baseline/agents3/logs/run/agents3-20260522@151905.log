from openpyxl import load_workbook

# Load the spreadsheet
file_path = "Names_Duplicate_Unique.xlsx"
wb = load_workbook(file_path)
sheet = wb.active

# Extract data from column "Names with duplicates"
duplicate_names = [cell.value for cell in sheet['B'] if cell.value is not None and cell.row > 1]

# Remove duplicates and preserve the order of first occurrences
unique_names = []
seen = set()
for name in duplicate_names:
    if name not in seen:
        seen.add(name)
        unique_names.append(name)

# Write the unique names to column "Unique Names"
for idx, name in enumerate(unique_names, start=2):  # Start writing from row 2
    sheet.cell(row=idx, column=3).value = name

# Save the modified file
wb.save(file_path)
```
