<answer>
```python
import openpyxl

# Load the workbook and get sheets
workbook = openpyxl.load_workbook('SmallBalanceSheet.xlsx')
sheet1 = workbook['Sheet1']
sheet2 = workbook['Sheet2']

# Write the years in the first column of Sheet2
for i, year in enumerate(range(2015, 2020), start=2):
    sheet2.cell(row=i, column=1).value = year

# Calculate percentage changes and write them into Sheet2
for row in range(3, 8):  # Corresponds to 2015 to 2019 (Sheet1 rows)
    prev_row = row - 1

    # Current Assets change
    ca_prev = sheet1.cell(row=prev_row, column=2).value
    ca_current = sheet1.cell(row=row, column=2).value
    ca_change = ((ca_current - ca_prev) / ca_prev) * 100 if ca_prev else 0
    sheet2.cell(row=row - 1, column=2).value = round(ca_change, 2)

    # Fixed Assets change
    fa_prev = sheet1.cell(row=prev_row, column=3).value
    fa_current = sheet1.cell(row=row, column=3).value
    fa_change = ((fa_current - fa_prev) / fa_prev) * 100 if fa_prev else 0
    sheet2.cell(row=row - 1, column=3).value = round(fa_change, 2)

    # Other Assets change
    oa_prev = sheet1.cell(row=prev_row, column=4).value
    oa_current = sheet1.cell(row=row, column=4).value
    oa_change = ((oa_current - oa_prev) / oa_prev) * 100 if oa_prev else 0
    sheet2.cell(row=row - 1, column=4).value = round(oa_change, 2)

# Save the workbook
workbook.save('SmallBalanceSheet.xlsx')
```
</answer>
