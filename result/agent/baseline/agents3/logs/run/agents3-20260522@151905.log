from openpyxl import load_workbook

# Load the workbook
workbook = load_workbook("Names_Duplicate_Unique.xlsx")
sheet = workbook.active

# Read names from column D ("Names with duplicates")
names = [sheet.cell(row=i, column=4).value for i in range(2, sheet.max_row + 1) if sheet.cell(row=i, column=4).value]

# Create a list of unique names preserving original order
unique_names = []
for name in names:
    if name not in unique_names:
        unique_names.append(name)

# Write unique names to column E ("Unique Names") starting from row 2
for i, unique_name in enumerate(unique_names, start=2):
    sheet.cell(row=i, column=5).value = unique_name

# Save the workbook with changes
workbook.save("Names_Duplicate_Unique.xlsx")
```
</answer>
