from openpyxl import load_workbook

# Load workbook and sheet
workbook_path = "Student_Grades_and_Remarks.xlsx"
wb = load_workbook(workbook_path)
sheet = wb.active

# Define the scale for remarks
scale = [
    (0, "Fail"),
    (30, "Pass"),
    (60, "Average"),
    (80, "Above average"),
    (90, "Excellent"),
    (100, "Exceptional")
]

# Function to fetch remarks based on marks
def get_remark(marks):
    for score, remark in reversed(scale):
        if marks >= score:
            return remark
    return "Unknown"

# Correctly assign remarks to the Message column
for row in range(10, 24):  # Rows corresponding to students
    marks_cell = f"E{row}"  # Marks in column 'E'
    message_cell = f"F{row}"  # Messages in column 'F'
    marks = sheet[marks_cell].value
    if isinstance(marks, (int, float)):  # Ensure marks are numeric
        sheet[message_cell] = get_remark(marks)

# Save the changes
wb.save(workbook_path)
```
</answer>
