from openpyxl import load_workbook

# Load the workbook
workbook_path = "SalesRep.xlsx"
wb = load_workbook(workbook_path)

# Access the active sheet
sheet1 = wb["Sheet1"]

# Calculate the total sales for each month
months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun"]
totals = []

# Sum each column that represents a month
for col_idx, month in enumerate(months, start=2):  # Assuming Month Columns Start at Column 2 (B)
    column_total = sum(cell.value for cell in sheet1.iter_cols(min_col=col_idx, max_col=col_idx, min_row=2, values_only=True) if cell)
    totals.append((month, column_total))

# Create new sheet and add data
sheet2 = wb.create_sheet(title="Sheet2")
sheet2.append(["Month", "Total"])  # Headers

# Append the month totals
for month, total in totals:
    sheet2.append([month, total])

# Save changes to the workbook
wb.save(workbook_path)
```
</answer>
