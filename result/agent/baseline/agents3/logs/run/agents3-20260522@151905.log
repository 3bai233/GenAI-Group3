```python
from openpyxl import load_workbook

# Reload the workbook
file_path = "SalesRep.xlsx"
workbook = load_workbook(filename=file_path)

# Access the sheets
sheet1 = workbook["Sheet1"]
sheet2 = workbook["Sheet2"]

# Extract headers from Sheet1 (months) and calculate totals for each month
headers = [cell.value for cell in sheet1[1]]
month_headers = headers[1:]  # Exclude "Sales Rep"
monthly_totals = [0] * len(month_headers)

for row in sheet1.iter_rows(min_row=2, values_only=True):  # Skip header row
    for i, value in enumerate(row[1:], start=0):  # Skip "Sales Rep"
        monthly_totals[i] += value

# Write to Sheet2
sheet2.cell(row=1, column=1, value="Month")
sheet2.cell(row=1, column=2, value="Total")
for i, month in enumerate(month_headers):
    sheet2.cell(row=i+2, column=1, value=month)
    sheet2.cell(row=i+2, column=2, value=monthly_totals[i])

# Save changes
workbook.save(file_path)
```
</answer>
