<answer>
```python
from openpyxl import load_workbook

# Load the workbook and select the active sheet
workbook_path = 'IncomeStatement2.xlsx'
workbook = load_workbook(workbook_path)
sheet1 = workbook.active

# Perform "Gross Profit" calculations
for row in range(2, sheet1.max_row + 1):
    net_sales = sheet1[f"E{row}"].value
    sales_return = sheet1[f"C{row}"].value
    discounts_allowances = sheet1[f"D{row}"].value
    materials_charges = sheet1[f"F{row}"].value
    labor_charges = sheet1[f"G{row}"].value
    overhead = sheet1[f"H{row}"].value
    total_cost_of_goods_sold = sheet1[f"I{row}"].value

    # Calculate Gross Profit
    gross_profit = net_sales - (sales_return + discounts_allowances + materials_charges + labor_charges + overhead + total_cost_of_goods_sold)
    sheet1[f"J{row}"] = gross_profit

# Create "Sheet2" for Year_Profit column
sheet2 = workbook.create_sheet(title="Sheet2")
sheet2.append(["Year_Profit"])  # Add header

for row in range(2, sheet1.max_row + 1):
    year = sheet1[f"A{row}"].value
    gross_profit = sheet1[f"J{row}"].value
    year_profit = f"{year}_{int(gross_profit)}"
    sheet2.append([year_profit])

# Save the workbook
workbook.save(workbook_path)
workbook.close()
```
</answer>
